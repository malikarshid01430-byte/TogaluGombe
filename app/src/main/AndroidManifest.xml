<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.togalugombe">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" />
    <uses-feature android:name="android.hardware.camera.autofocus" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Togalu Gombe"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TogaluGombe">

        <!-- LOGIN SCREEN -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MAIN SCREEN -->
        <activity
            android:name=".ui.HomeActivity"
            android:exported="false" />

        <!-- SECOND SCREEN (NO intent-filter → no need exported) -->
        <activity
            android:name=".ui.GalleryActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ScanActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".ui.SignUpActivity"
            android:exported="false" />

        <activity
            android:name=".ui.SavedActivity"
            android:exported="false" />

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false" />

        <!-- Detail screen placeholder or remove if not needed -->
        <!-- <activity android:name=".ui.DetailActivity" android:exported="false" /> -->

    </application>

</manifest>